# Copy to `.env.local` and fill in values. Never commit `.env.local`.
#
# "Target" = where you run the app:
#   local  → npm run dev + Stripe CLI webhook forward (below)
#   vercel → set the same vars in Project → Settings → Environment Variables

# --- App ---
NEXT_PUBLIC_APP_URL=http://localhost:3000

# Auth (use a long random string in production)
AUTH_SECRET=change-me-to-a-long-random-string
# JWT_SECRET=optional-alias-for-AUTH_SECRET

# --- Neon Postgres (required for durable markets / ledger / withdrawals on deploy) ---
# Dashboard: Connection details → use the *pooled* connection string (host often ends in -pooler)
# App reads POSTGRES_URL first, then DATABASE_URL.
POSTGRES_URL=postgresql://USER:PASSWORD@HOST/neondb?sslmode=require
# DATABASE_URL=

# --- OpenAI (Peak AI feed markets + user peak → market cards) ---
OPENAI_API_KEY=
# OPENAI_MODEL=gpt-5
# TAVILY_API_KEY=
# FEED_AUTOGEN_MIN_INTERVAL_MS=30000
# CRON_MARKET_COUNT=24

# --- Twitch live betting widget (OBS browser source + viewer panel) ---
# TWITCH_DEFAULT_CHANNEL=your_twitch_login
# TWITCH_DEFAULT_MARKET_ID=uuid-of-market-to-show-when-channel-has-no-pin

# --- Stripe (Peakpoints *deposits* via Checkout — not withdrawals) ---
STRIPE_SECRET_KEY=sk_test_...
STRIPE_WEBHOOK_SECRET=whsec_...
# Optional subscription prices (pricing page)
# STRIPE_PRICE_PEAKPLUS=
# STRIPE_PRICE_PEAKPRO=
# STRIPE_PRICE_PEAKENTERPRISE=

# --- Dev-only: skip Stripe and POST deposit to /api/peakpoints ---
# ALLOW_STUB_PEAKPOINTS_DEPOSIT=true

# --- Cron + admin (Vercel crons in vercel.json; optional for local manual calls) ---
CRON_SECRET=change-me-cron-secret
ADMIN_EMAILS=you@example.com

# --- Live tab (optional) ---
# LIVEKIT_API_KEY=
# LIVEKIT_API_SECRET=
# NEXT_PUBLIC_LIVEKIT_URL=

# --- Peak Anime video storage (Cloudflare R2 recommended for production) ---
# When set, PeakPro uploads go direct to R2 (bypasses Vercel body size limits).
# Leave unset for local dev — videos save to data/uploads/anime/
# R2_ACCOUNT_ID=
# R2_ACCESS_KEY_ID=
# R2_SECRET_ACCESS_KEY=
# R2_BUCKET_NAME=
# R2_ENDPOINT=https://<account_id>.r2.cloudflarestorage.com
# R2_REGION=auto
# Generic S3-compatible aliases also work: S3_ENDPOINT, S3_ACCESS_KEY_ID, S3_SECRET_ACCESS_KEY
#
# R2 bucket CORS (required for browser direct upload):
#   Allowed origins: https://peaksees.vercel.app (and http://localhost:3000 for dev)
#   Methods: PUT, GET, HEAD
#   Headers: Content-Type, *
