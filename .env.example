# Copy to `.env.local` and fill in values. Never commit `.env.local`.
#
# "Target" = where you run the app:
#   local  → npm run dev + Stripe CLI webhook forward (below)
#   vercel → set the same vars in Project → Settings → Environment Variables

# --- App ---
NEXT_PUBLIC_APP_URL=http://localhost:3000
# Phone LAN preview (npm run dev:lan): your PC Wi‑Fi IPv4 from ipconfig
# DEV_LAN_HOST=192.168.12.132

# Auth (use a long random string in production)
AUTH_SECRET=change-me-to-a-long-random-string
# JWT_SECRET=optional-alias-for-AUTH_SECRET

# --- Neon Postgres (required for durable markets / ledger / withdrawals on deploy) ---
# Dashboard: Connection details → use the *pooled* connection string (host often ends in -pooler)
# App reads POSTGRES_URL first, then DATABASE_URL.
POSTGRES_URL=postgresql://USER:PASSWORD@HOST/neondb?sslmode=require
# DATABASE_URL=

# --- OpenAI (Peak AI feed markets + user peak → market cards) ---
OPENAI_API_KEY=
# OPENAI_MODEL=gpt-4o-mini
# TAVILY_API_KEY=

# --- Stripe (Peakpoints *deposits* via Checkout — not withdrawals) ---
STRIPE_SECRET_KEY=sk_test_...
STRIPE_WEBHOOK_SECRET=whsec_...
# Optional subscription prices (pricing page)
# STRIPE_PRICE_PEAKPLUS=
# STRIPE_PRICE_PEAKPRO=
# STRIPE_PRICE_PEAKENTERPRISE=

# --- Dev-only: skip Stripe and POST deposit to /api/peakpoints ---
# ALLOW_STUB_PEAKPOINTS_DEPOSIT=true

# --- Cron + admin (Vercel crons in vercel.json; optional for local manual calls) ---
CRON_SECRET=change-me-cron-secret
ADMIN_EMAILS=you@example.com

# --- Live tab (optional) ---
# LIVEKIT_API_KEY=
# LIVEKIT_API_SECRET=
# NEXT_PUBLIC_LIVEKIT_URL=
